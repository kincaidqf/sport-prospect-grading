# Copy to .env and fill in values
PYTHONPATH=.

WANDB_API_KEY=
WANDB_MODE=offline   # set to online to sync runs

# Override compute device: cuda | mps | cpu (auto-detected if unset)
DEVICE=

# Shared MLflow backend for the whole team.
# Examples:
#   MLFLOW_TRACKING_URI=http://your-mlflow-server:5000
#   MLFLOW_TRACKING_URI=/Volumes/SharedDrive/sport-prospect-grading/mlruns
MLFLOW_TRACKING_URI=
MLFLOW_ARTIFACT_LOCATION=
MLFLOW_RUN_NAME=
